{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://creator-engine.local/schemas/package_manifest.schema.json",
  "title": "Package Manifest",
  "type": "object",
  "required": ["packageId", "createdAt", "recipeUsed", "sourceMedia", "exports"],
  "properties": {
    "packageId": { "type": "string" },
    "createdAt": { "type": "string" },
    "recipeUsed": { "type": "string" },
    "sourceMedia": { "type": "string" },
    "exports": { "type": "array", "items": { "type": "string" } },
    "thumbnails": { "type": "array", "items": { "type": "string" } },
    "captions": { "type": "array", "items": { "type": "string" } },
    "notes": { "type": "array", "items": { "type": "string" } },
    "checks": { "type": "array", "items": { "type": "string" } },
    "warnings": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
