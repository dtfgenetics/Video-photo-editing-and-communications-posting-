# Creator Engine local configuration example
# Copy to .env locally. Never commit real secrets.

APP_ENV=development
APP_PORT=4200
API_PORT=4300

# Local storage root
STORAGE_ROOT=./storage

# Optional dependency paths
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# Job settings
MAX_CONCURRENT_JOBS=1
DEFAULT_EXPORT_QUALITY=balanced

# Optional connectors - leave blank until configured locally
DISCORD_WEBHOOK_URL=
WORDPRESS_BASE_URL=
WORDPRESS_API_USER=
WORDPRESS_API_TOKEN=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
OPENAI_API_KEY=

# Security
ENABLE_PLUGIN_SANDBOX=true
LOG_LEVEL=info
